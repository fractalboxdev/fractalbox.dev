---
// View-transition styling only. The visible "rotating gridline" overlay
// has been removed — page entry rotation is now driven by IFSBackground
// itself, so there's no separate veil element to animate.
//
// This component is a pure CSS provider: it injects the global
// ::view-transition-* keyframes that give navigations the helical-zoom feel.
---

<style is:global>
	@view-transition { navigation: auto; }

	/* Heavy crossfade: new page begins emerging at 60ms (effectively as soon as
	   the old page starts fading), so most of the transition is both layers
	   simultaneously visible — content is never absent from the viewport. */
	::view-transition-old(root),
	::view-transition-new(root) {
		mix-blend-mode: normal;
		transform-origin: var(--zoom-origin, 50% 50%);
	}
	::view-transition-old(root) {
		animation-name: fb-zoom-past;
		animation-duration: 380ms;
		animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
		animation-fill-mode: forwards;
	}
	::view-transition-new(root) {
		animation-name: fb-zoom-emerge;
		animation-duration: 520ms;
		animation-delay: 60ms;
		animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
		animation-fill-mode: backwards;
	}
	@keyframes fb-zoom-past {
		0%   { opacity: 1;    transform: scale(1)    rotate(0deg);  filter: blur(0); }
		100% { opacity: 0;    transform: scale(1.32) rotate(3deg);  filter: blur(2px); }
	}
	@keyframes fb-zoom-emerge {
		0%   { opacity: 0;    transform: scale(0.84) rotate(-3deg); filter: blur(3px); }
		35%  { opacity: 0.6;  transform: scale(0.92) rotate(-1.5deg); filter: blur(1.5px); }
		100% { opacity: 1;    transform: scale(1)    rotate(0deg);  filter: blur(0); }
	}

	@media (prefers-reduced-motion: reduce) {
		::view-transition-old(root),
		::view-transition-new(root) { animation: none !important; }
	}
</style>
