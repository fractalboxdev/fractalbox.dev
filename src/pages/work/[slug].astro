---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../../layouts/FractalMay2026.astro";

export async function getStaticPaths() {
	const cases = await getCollection("client", ({ data }) => data.featured);
	return cases.map((c) => ({ params: { slug: c.id }, props: { entry: c } }));
}

const { entry } = Astro.props;
const studio = (await getEntry("site", "studio"))!.data;
const { Content } = await render(entry);
const c = entry.data;
---
<Layout
	title={`fractalbox.dev — ${c.title}`}
	active="work"
	iter={4}
	pageTag={`§IV · WORK · ${c.title.toUpperCase()}`}
	pageGreek="ƒ⁴(△) — one case · in depth"
>
	<section style="padding-top:4rem;">
		<div class="wrap">
			<div class="eyebrow"><span class="blink"></span> // case study</div>
			<h1 class="serif-h1">{c.title}</h1>
			<p class="serif-lede">{c.problem}</p>

			{c.metric && (
				<div style="margin-top:2rem;">
					<div style="font-family:'JetBrains Mono',monospace; color:var(--amber); font-size:3.5rem; letter-spacing:-0.01em; line-height:1; text-shadow:0 0 12px rgba(210,168,87,0.4);">{c.metric}</div>
					<div style="font-family:'JetBrains Mono',monospace; color:var(--muted); font-size:0.72rem; letter-spacing:0.16em; text-transform:uppercase; margin-top:0.55rem;">{c.metricLabel}</div>
				</div>
			)}

			<div style="display:grid; gap:0.6rem; grid-template-columns:1fr; margin-top:2rem; max-width:48rem;">
				<div style="display:grid; grid-template-columns:7rem 1fr; gap:1rem; padding:0.5rem 0; border-top:1px solid var(--border);">
					<span style="color:var(--muted); font-family:'JetBrains Mono',monospace; font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase;">role</span>
					<span style="font-family:'JetBrains Mono',monospace; font-size:0.85rem;">{c.role}</span>
				</div>
				{c.duration && (
					<div style="display:grid; grid-template-columns:7rem 1fr; gap:1rem; padding:0.5rem 0; border-top:1px solid var(--border);">
						<span style="color:var(--muted); font-family:'JetBrains Mono',monospace; font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase;">duration</span>
						<span style="font-family:'JetBrains Mono',monospace; font-size:0.85rem;">{c.duration}</span>
					</div>
				)}
				<div style="display:grid; grid-template-columns:7rem 1fr; gap:1rem; padding:0.5rem 0; border-top:1px solid var(--border); border-bottom:1px solid var(--border);">
					<span style="color:var(--muted); font-family:'JetBrains Mono',monospace; font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase;">stack</span>
					<span style="display:flex; gap:0.4rem; flex-wrap:wrap;">
						{(c.stack ?? []).map((s) => (
							<span style="font-family:'JetBrains Mono',monospace; font-size:0.72rem; padding:0.15rem 0.5rem; border:1px solid var(--border); color:var(--mint);">{s}</span>
						))}
					</span>
				</div>
			</div>
		</div>
	</section>

	<section>
		<div class="wrap">
			<article class="case-body">
				<Content />
			</article>
		</div>
	</section>

	<section>
		<div class="wrap" style="text-align:center;">
			<div class="section-tag" style="justify-content:center;"><span class="dot"></span> // continue iterating</div>
			<h2 class="serif-h2" style="margin:0.5rem auto 1.5rem; max-width:none;">Talk to Us</h2>
			<div style="display:flex; gap:0.75rem; justify-content:center; flex-wrap:wrap;">
				<a class="btn" href="/work">▸ all work</a>
				<a class="btn primary" href={`mailto:${studio.email}`}>↪ {studio.email}</a>
			</div>
		</div>
	</section>

	<style>
		.case-body {
			max-width: 44rem;
			color: var(--fg-soft);
			font-size: 1rem;
			line-height: 1.75;
		}
		.case-body :global(h2) {
			font-family: "JetBrains Mono", monospace;
			font-weight: 600;
			color: var(--fg);
			font-size: 1.4rem;
			margin: 2.5rem 0 0.8rem;
			letter-spacing: -0.015em;
		}
		.case-body :global(h3) {
			font-family: "JetBrains Mono", monospace;
			color: var(--mint);
			font-size: 1rem;
			margin: 1.6rem 0 0.4rem;
		}
		.case-body :global(p) { margin: 0 0 1rem; }
		.case-body :global(ol),
		.case-body :global(ul) { margin: 0 0 1rem; padding-left: 1.4rem; }
		.case-body :global(li) { margin: 0.4rem 0; }
		.case-body :global(strong) { color: var(--amber); font-weight: 600; }
		.case-body :global(code) {
			font-family: "JetBrains Mono", monospace;
			color: var(--mint);
			background: var(--bg-elevated);
			padding: 0.05em 0.4em;
			border: 1px solid var(--border);
			font-size: 0.92em;
		}
	</style>
</Layout>
