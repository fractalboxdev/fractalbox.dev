---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { getCollection, getEntry } from "astro:content";
import Layout from "../layouts/FractalMay2026.astro";
import BoxDimChip from "../components/BoxDimChip.astro";

const studio = (await getEntry("site", "studio"))!.data;
const team = (await getCollection("people")).sort((a, b) => a.data.order - b.data.order);
const writing = (await getCollection("writing")).sort((a, b) => a.data.order - b.data.order);

const avatarPaths = import.meta.glob<{ default: ImageMetadata }>(
	"/src/assets/avatar*.{jpeg,jpg,png,gif,svg}",
);
---
<Layout
	title="fractalbox.dev — team"
	active="team"
	iter={5}
	pageTag="§V · TEAM"
	pageGreek="ƒ⁵(△) — operators, not consultants"
>
	<section style="padding-top:5rem;">
		<div class="wrap">
			<div class="eyebrow"><span class="blink"></span> // §V · the operators</div>
			<h1 class="serif-h1">Operators, not <span style="color:var(--mint);">consultants</span>.</h1>
			<p class="serif-lede">Names on the field-team roster. Code commits land under our handles, on-call rotation includes us.</p>
			<p class="serif-lede" style="margin-top:1rem; font-size:1rem; color:var(--math); font-style:italic;">{studio.boxLine}</p>
			<div style="margin-top:1.25rem; display:flex; gap:0.6rem; flex-wrap:wrap; --chip-color: var(--mint); --chip-border: var(--border-hi); --chip-bg: var(--bg-elevated); --chip-name: var(--amber); --chip-val: var(--math);">
				<span class="eq-chip">i = 5</span>
				<BoxDimChip for="sierpinski" label="depth 5" />
			</div>
		</div>
	</section>

	<section>
		<div class="wrap">
			<div class="section-tag"><span class="dot"></span> // team of record</div>
			<p class="lede">ETHGlobal Finalist × 3 · ex-Animoca / PALO IT / Mon Studio.</p>

			<div class="card-grid cols-2" style="margin-top:2.5rem;">
				{team.map((m) => {
					const loader = m.data.avatar ? avatarPaths[`/${m.data.avatar}`] : undefined;
					return (
						<article class="card-cell">
							{loader ? (
								<div class="avatar-frame">
									<Image
										src={loader()}
										alt={m.data.name}
										width={120}
										height={120}
										class="avatar-img"
									/>
								</div>
							) : (
								<div class="avatar-fallback">
									{m.data.name.slice(0, 2).toUpperCase()}
								</div>
							)}
							<h3 class="serif-h3" style="margin:0; font-size:1.15rem;">{m.data.name}</h3>
							<div style="color:var(--mint); font-family:'JetBrains Mono',monospace; font-size:0.72rem; letter-spacing:0.12em; text-transform:uppercase;">{m.data.role}</div>
							<div style="color:var(--muted); font-size:0.88rem;">{m.data.creds}</div>
						</article>
					);
				})}
			</div>
		</div>
	</section>

	<section>
		<div class="wrap">
			<div class="section-tag"><span class="dot"></span> // notes from the field</div>
			<h2 class="serif-h2">Writing &amp; public goods.</h2>
			<div style="margin-top:2rem; border:1px solid var(--border); background:var(--bg-card);">
				{writing.map((w, i) => (
					<a href={w.data.href ?? "#"} style="display:grid; grid-template-columns:5rem 1fr auto; align-items:center; gap:1rem; padding:1.1rem 1.25rem; border-bottom:1px solid var(--border); color:var(--fg);">
						<div style="color:var(--mint); font-family:'JetBrains Mono',monospace; font-size:0.72rem; letter-spacing:0.12em;">post / 0{i + 1}</div>
						<div class="serif" style="font-style:italic;">{w.data.title}</div>
						<div style="color:var(--mint); font-family:'JetBrains Mono',monospace;">↗</div>
					</a>
				))}
			</div>
			<p style="margin-top:1.5rem; color:var(--muted);">Open-source artefacts: <a href="https://github.com/fractaldotbox">github.com/fractaldotbox</a></p>
		</div>
	</section>

	<section>
		<div class="wrap" style="text-align:center;">
			<div class="section-tag" style="justify-content:center;"><span class="dot"></span> // next iteration</div>
			<h2 class="serif-h2" style="margin:0.5rem auto 1.5rem; max-width:none;">Start Shipping</h2>
			<a class="btn primary" href="/contact">Talk to Us</a>
		</div>
	</section>

	<style>
		.avatar-frame {
			width: 80px; height: 80px;
			border: 1px solid var(--mint);
			padding: 3px;
			background: rgba(176, 222, 240, 0.04);
			box-shadow: inset 0 0 12px rgba(176, 222, 240, 0.15);
			position: relative;
		}
		.avatar-frame::before, .avatar-frame::after {
			content: ""; position: absolute; width: 8px; height: 8px;
			border: 1px solid var(--mint);
		}
		.avatar-frame::before { top: -1px; left: -1px; border-right: none; border-bottom: none; }
		.avatar-frame::after { bottom: -1px; right: -1px; border-left: none; border-top: none; }
		.avatar-img {
			width: 100%; height: 100%;
			object-fit: cover;
			display: block;
		}
		.avatar-fallback {
			width: 80px; height: 80px;
			border: 1px solid var(--mint);
			display: grid; place-items: center;
			color: var(--mint);
			font-family: "JetBrains Mono", monospace;
			font-size: 1.4rem;
			background: rgba(176, 222, 240, 0.04);
			box-shadow: inset 0 0 12px rgba(176, 222, 240, 0.15);
		}
	</style>
</Layout>
