---
// /f — the Mandelbrot plane, cursor as the parameter c. Standalone
// fullscreen page — deliberately outside the site layout.
//
// Origin = centre of the viewport. The cursor's offset from it maps
// LINEARLY to the complex plane, so the cursor tip *is* c — unlike the
// front page's log-remapped Julia console. Pure line-work, no escape-time
// image behind: one canvas draws the live orbit of 0 under z → z² + c as
// connected points, the visualization from Numberphile's "What's so
// special about the Mandelbrot Set?" (youtube.com/watch?v=FFftmWSzgmk,
// Ben Sparks' GeoGebra demo).
//
// One point on the plane is special: c ≈ 0.3 + 0.85i — around 3:41 in the
// video its orbit strokes sketch the character ƒ. A dashed ring marks it;
// whenever the cursor reaches it the whole drawing shifts from mint
// phosphor to amber.
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content="ƒ — the Mandelbrot plane. Your cursor is c; the orbit of 0 under z → z² + c is drawn live." />
		<title>fractalbox.dev — ƒ · mandelbrot</title>
	</head>
	<body>
		<a class="f-home" href="/">◂ fractal.box</a>
		<div class="f-head">MANDELBROT · Z → Z² + C</div>
		<canvas id="f-orbit" aria-hidden="true"></canvas>
		<div class="f-readout">
			<span id="f-status">● TRACE</span>
			<span id="f-c-readout">C = 0.000 + 0.000i</span>
		</div>
	</body>
</html>

<style>
	:root {
		--bg: #0a0a0a;
		--mint: #b0def0;
		--amber: #f0d68f;
		--muted: #b8c0cc;
	}
	html, body {
		margin: 0; height: 100%; overflow: hidden;
		background: var(--bg); color: var(--mint);
		font-family: "JetBrains Mono", "IBM Plex Mono", "SF Mono", ui-monospace, "Menlo", monospace;
	}
	canvas#f-orbit {
		position: fixed; inset: 0; width: 100vw; height: 100vh; display: block;
	}
	.f-home {
		position: fixed; top: 0.85rem; left: 1rem; z-index: 2;
		color: var(--muted); opacity: 0.7; text-decoration: none;
		font-size: 0.7rem; letter-spacing: 0.16em; text-transform: uppercase;
	}
	.f-home:hover { color: var(--mint); opacity: 1; }
	.f-head {
		position: fixed; top: 0.85rem; left: 50%; transform: translateX(-50%); z-index: 2;
		color: var(--mint); font-size: 0.7rem;
		letter-spacing: 0.2em; text-transform: uppercase; white-space: nowrap;
	}
	.f-readout {
		position: fixed; bottom: 0.85rem; left: 1rem; right: 1rem; z-index: 2;
		display: flex; justify-content: flex-start; gap: 1.75rem; pointer-events: none;
		font-size: 0.65rem; color: var(--muted); letter-spacing: 0.1em;
	}
	.f-readout span:first-child { color: var(--mint); }
	body.f-locked .f-readout span:first-child,
	body.f-locked .f-head { color: var(--amber); }
</style>

<script>
	// The ƒ-point — c whose orbit strokes the character ƒ (Numberphile
	// FFftmWSzgmk @ 3:41). Reaching it within LOCK_RADIUS re-colors the drawing.
	const F_RE = 0.3;
	const F_IM = 0.85;
	const LOCK_RADIUS = 0.075;

	const ORBIT_ITER = 80;
	const MINT = "176,222,240";
	const AMBER = "240,214,143";
	// Bounded rosette near the 1/4-bulb — the resting orbit before the
	// first pointer event (and the mobile landing state).
	const IDLE_RE = 0.28;
	const IDLE_IM = 0.53;

	const reduced = window.matchMedia?.("(prefers-reduced-motion: reduce)").matches;

	const canvas = document.getElementById("f-orbit") as HTMLCanvasElement;
	const readC = document.getElementById("f-c-readout");
	const readStatus = document.getElementById("f-status");

	const state = {
		w: 0, h: 0, scale: 1,
		cR: IDLE_RE, cI: IDLE_IM,
		locked: false,
		status: "",
	};

	const pointer = { x: 0, y: 0, active: false };
	const onPointer = (e: PointerEvent) => {
		pointer.x = e.clientX;
		pointer.y = e.clientY;
		pointer.active = true;
	};
	window.addEventListener("pointermove", onPointer, { passive: true });
	window.addEventListener("pointerdown", onPointer, { passive: true });

	function layout() {
		state.w = window.innerWidth;
		state.h = window.innerHeight;
		// The escape circle (|z| = 2) and the ƒ-point stay on-screen at
		// every aspect ratio.
		state.scale = Math.min(state.w / 4.8, state.h / 2.8);
		canvas.width = state.w;
		canvas.height = state.h;
	}
	window.addEventListener("resize", layout);
	layout();

	function drawOrbit(now: number) {
		const ctx = canvas.getContext("2d");
		if (!ctx) return;
		const W = state.w, H = state.h, s = state.scale;
		const cx = W / 2, cy = H / 2;
		const ink = state.locked ? AMBER : MINT;
		ctx.clearRect(0, 0, W, H);

		// Axes through the origin + dashed escape circle |z| = 2.
		ctx.strokeStyle = `rgba(${ink},0.16)`;
		ctx.lineWidth = 1;
		ctx.beginPath();
		ctx.moveTo(0, cy); ctx.lineTo(W, cy);
		ctx.moveTo(cx, 0); ctx.lineTo(cx, H);
		ctx.stroke();
		ctx.setLineDash([2, 5]);
		ctx.strokeStyle = `rgba(${ink},0.14)`;
		ctx.beginPath();
		ctx.arc(cx, cy, 2 * s, 0, Math.PI * 2);
		ctx.stroke();
		ctx.setLineDash([]);

		// ƒ-point marker — dashed ring showing the exact lock zone.
		const fx = cx + F_RE * s;
		const fy = cy - F_IM * s;
		const ringR = LOCK_RADIUS * s;
		const pulse = reduced || state.locked ? 1 : 0.65 + 0.35 * Math.sin(now / 480);
		ctx.setLineDash(state.locked ? [] : [3, 4]);
		ctx.strokeStyle = `rgba(${ink},${0.75 * pulse})`;
		ctx.lineWidth = state.locked ? 1.5 : 1;
		ctx.beginPath();
		ctx.arc(fx, fy, ringR, 0, Math.PI * 2);
		ctx.stroke();
		ctx.setLineDash([]);
		ctx.fillStyle = `rgba(${ink},${0.9 * pulse})`;
		ctx.font = `italic 600 ${Math.max(16, Math.round(s * 0.1))}px "STIX Two Text", "Cambria Math", Cambria, Georgia, serif`;
		ctx.textBaseline = "bottom";
		ctx.fillText("ƒ", fx + ringR + 5, fy - ringR - 2);
		if (state.locked) {
			ctx.font = '10px "JetBrains Mono", monospace';
			ctx.textBaseline = "top";
			ctx.fillStyle = `rgba(${ink},0.85)`;
			ctx.fillText("0.300 + 0.850i", fx + ringR + 5, fy + ringR + 4);
		}

		// Orbit of 0 under z → z² + c — connected points, capped once
		// |z| clears the escape radius by a wide margin.
		const pts: [number, number][] = [[0, 0]];
		let zR = 0, zI = 0;
		let escaped = -1;
		for (let i = 0; i < ORBIT_ITER; i++) {
			const r2 = zR * zR;
			const i2 = zI * zI;
			if (r2 + i2 > 16) { escaped = i; break; }
			zI = 2 * zR * zI + state.cI;
			zR = r2 - i2 + state.cR;
			pts.push([zR, zI]);
		}
		ctx.strokeStyle = `rgba(${ink},0.5)`;
		ctx.lineWidth = 1;
		ctx.beginPath();
		pts.forEach(([re, im], i) => {
			const x = cx + re * s;
			const y = cy - im * s;
			if (i === 0) ctx.moveTo(x, y);
			else ctx.lineTo(x, y);
		});
		ctx.stroke();
		ctx.fillStyle = `rgba(${ink},0.9)`;
		pts.forEach(([re, im], i) => {
			const d = i === 0 ? 4 : 2.5;
			ctx.fillRect(cx + re * s - d / 2, cy - im * s - d / 2, d, d);
		});
		return escaped;
	}

	function tick(now: number) {
		const originX = state.w / 2;
		const originY = state.h / 2;
		const targetR = pointer.active ? (pointer.x - originX) / state.scale : IDLE_RE;
		const targetI = pointer.active ? (originY - pointer.y) / state.scale : IDLE_IM;
		const k = reduced ? 1 : 0.12;
		state.cR += (targetR - state.cR) * k;
		state.cI += (targetI - state.cI) * k;

		// Lock on the raw cursor c — the tip must actually reach ƒ.
		const locked = Math.hypot(targetR - F_RE, targetI - F_IM) < LOCK_RADIUS;
		if (locked !== state.locked) {
			state.locked = locked;
			document.body.classList.toggle("f-locked", locked);
		}

		const escaped = drawOrbit(now);

		if (readC) {
			const sign = state.cI >= 0 ? "+" : "−";
			readC.textContent = `C = ${state.cR.toFixed(3)} ${sign} ${Math.abs(state.cI).toFixed(3)}i`;
		}
		const status = locked
			? "ƒ · LOCKED"
			: escaped === undefined || escaped < 0
				? `● BOUNDED · ${ORBIT_ITER} ITER`
				: `● ESCAPES @ N=${escaped}`;
		if (readStatus && status !== state.status) {
			state.status = status;
			readStatus.textContent = status;
		}

		requestAnimationFrame(tick);
	}

	requestAnimationFrame(tick);
</script>
