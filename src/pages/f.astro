---
// /f — the Mandelbrot set itself, cursor as the parameter c.
//
// Origin = centre of the stage (the page's first viewport). The cursor's
// offset from that origin maps LINEARLY to the complex plane, so the cursor
// tip *is* c — unlike the front page's log-remapped Julia console. The set
// is rendered once to a static canvas; a second overlay canvas draws the
// live orbit of 0 under z → z² + c as connected points, the visualization
// from Numberphile's "What's so special about the Mandelbrot Set?"
// (youtube.com/watch?v=FFftmWSzgmk, Ben Sparks' GeoGebra demo).
//
// One point on the plane is special: c ≈ 0.3 + 0.85i — around 3:41 in the
// video its orbit strokes sketch the character ƒ. A dashed ring marks it;
// whenever the cursor reaches it the whole visualization shifts from mint
// phosphor to amber.
import Layout from "../layouts/FractalMay2026.astro";
---
<Layout
	title="fractalbox.dev — ƒ · mandelbrot"
	active="logos"
	iter={5}
	pageTag="§ƒ · MANDELBROT"
	pageGreek="M = { c ∈ ℂ : ƒ_c^n(0) bounded } · ƒ_c(z) = z² + c"
	hudBottomRight="ƒc(z) = z² + c · |c| ≤ 2"
>
	<section style="padding-top:2.5rem; padding-bottom:0;">
		<div class="wrap">
			<div class="eyebrow"><span class="blink"></span> // §ƒ · the set itself</div>
			<h1 class="serif-h3" style="margin:0.6rem 0 0.4rem; max-width:44rem;">The Mandelbrot set — every Julia set's table of contents.</h1>
			<p class="lede" style="font-size:0.88rem;">
				Your cursor is <span class="var">c</span>. The orbit of 0 under
				<span class="var">z → z² + c</span> is drawn live. One point on this plane
				strokes an <span class="var">ƒ</span> — reach it.
			</p>
		</div>
	</section>

	<section style="padding-top:1.5rem;">
		<div class="wrap">
			<div class="f-stage" id="f-stage">
				<span class="fc fc-tl"></span><span class="fc fc-tr"></span>
				<span class="fc fc-bl"></span><span class="fc fc-br"></span>
				<div class="f-head">MANDELBROT · Z → Z² + C</div>
				<canvas class="f-mandel" aria-hidden="true"></canvas>
				<canvas class="f-orbit" aria-hidden="true"></canvas>
				<div class="f-readout">
					<span id="f-status">● TRACE</span>
					<span id="f-c-readout">C = 0.000 + 0.000i</span>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.f-stage {
		position: relative;
		height: max(480px, calc(100svh - 16rem));
		border: 1px solid var(--border-hi);
		background: linear-gradient(180deg, rgba(176,222,240,0.04), transparent 60%);
		overflow: hidden;
	}
	/* Corner brackets — same grammar as .console, hand-rolled since the
	   console class carries aspect-ratio/max-width we don't want here. */
	.f-stage .fc {
		position: absolute; width: 18px; height: 18px;
		border: 1px solid var(--mint); z-index: 3; pointer-events: none;
	}
	.f-stage .fc-tl { top: -1px; left: -1px; border-right: none; border-bottom: none; }
	.f-stage .fc-tr { top: -1px; right: -1px; border-left: none; border-bottom: none; }
	.f-stage .fc-bl { bottom: -1px; left: -1px; border-right: none; border-top: none; }
	.f-stage .fc-br { bottom: -1px; right: -1px; border-left: none; border-top: none; }
	.f-head {
		position: absolute; top: -1px; left: 50%; transform: translate(-50%, -50%);
		background: var(--bg); padding: 0 0.6rem; color: var(--mint); z-index: 3;
		font-family: "JetBrains Mono", monospace; font-size: 0.7rem;
		letter-spacing: 0.2em; text-transform: uppercase; white-space: nowrap;
	}
	canvas.f-mandel, canvas.f-orbit {
		position: absolute; inset: 0; width: 100%; height: 100%; display: block;
	}
	canvas.f-mandel {
		image-rendering: pixelated;
		transition: filter 480ms ease;
	}
	/* mint (~197°) → amber (~44°): the whole set re-colors when c reaches ƒ. */
	.f-stage.f-locked canvas.f-mandel {
		filter: hue-rotate(-153deg) saturate(1.35) brightness(1.05);
	}
	/* Both readouts sit left — the viewport's fixed HUD tag owns bottom-right. */
	.f-readout {
		position: absolute; bottom: 0.6rem; left: 0.85rem; right: 0.85rem; z-index: 3;
		display: flex; justify-content: flex-start; gap: 1.75rem; pointer-events: none;
		font-family: "JetBrains Mono", monospace; font-size: 0.65rem;
		color: var(--muted); letter-spacing: 0.1em;
	}
	.f-readout span:first-child { color: var(--mint); }
	.f-stage.f-locked .f-readout span:first-child { color: var(--amber); }
	.f-stage.f-locked .f-head { color: var(--amber); }
	.f-stage.f-locked .fc { border-color: var(--amber); }
</style>

<script>
	declare global {
		interface Window {
			__fMandelInit?: boolean;
		}
	}

	if (!window.__fMandelInit) {
		window.__fMandelInit = true;

		// The ƒ-point — c whose orbit strokes the character ƒ (Numberphile
		// FFftmWSzgmk @ 3:41). Reaching it within LOCK_RADIUS re-colors the set.
		const F_RE = 0.3;
		const F_IM = 0.85;
		const LOCK_RADIUS = 0.075;

		const MAX_ITER = 96;
		const ORBIT_ITER = 80;
		const MINT = "176,222,240";
		const AMBER = "240,214,143";
		// Bounded rosette near the 1/4-bulb — the resting orbit before the
		// first pointer event (and the mobile landing state).
		const IDLE_RE = 0.28;
		const IDLE_IM = 0.53;

		const reduced = window.matchMedia?.("(prefers-reduced-motion: reduce)").matches;

		// Escape-time palette: transparent far exterior ramping to white-hot
		// mint at the boundary; interior stays a faint silhouette.
		const palette = new Uint8ClampedArray(MAX_ITER * 4);
		for (let i = 0; i < MAX_ITER; i++) {
			const b = Math.pow(i / (MAX_ITER - 1), 0.42);
			const off = i * 4;
			palette[off]     = Math.round(176 + 79 * b);
			palette[off + 1] = Math.round(222 + 33 * b);
			palette[off + 2] = Math.round(240 + 15 * b);
			palette[off + 3] = Math.round(235 * b);
		}

		const pointer = { x: 0, y: 0, active: false };
		const onPointer = (e: PointerEvent) => {
			pointer.x = e.clientX;
			pointer.y = e.clientY;
			pointer.active = true;
		};
		window.addEventListener("pointermove", onPointer, { passive: true });
		window.addEventListener("pointerdown", onPointer, { passive: true });

		let genToken = 0;

		function renderMandel(canvas: HTMLCanvasElement, scale: number) {
			const ctx = canvas.getContext("2d");
			if (!ctx) return;
			const W = canvas.width, H = canvas.height;
			const img = ctx.createImageData(W, H);
			const data = img.data;
			for (let py = 0; py < H; py++) {
				const ci = (H / 2 - py) / scale;
				for (let px = 0; px < W; px++) {
					const cr = (px - W / 2) / scale;
					const off = (py * W + px) * 4;
					// Analytic interior early-outs — main cardioid + period-2 bulb.
					const xq = cr - 0.25;
					const q = xq * xq + ci * ci;
					const inCardioid = q * (q + xq) < 0.25 * ci * ci;
					const inBulb = (cr + 1) * (cr + 1) + ci * ci < 0.0625;
					let i = MAX_ITER;
					if (!inCardioid && !inBulb) {
						let zR = 0, zI = 0;
						i = 0;
						while (i < MAX_ITER) {
							const r2 = zR * zR;
							const i2 = zI * zI;
							if (r2 + i2 > 4) break;
							zI = 2 * zR * zI + ci;
							zR = r2 - i2 + cr;
							i++;
						}
					}
					if (i === MAX_ITER) {
						data[off]     = 176;
						data[off + 1] = 222;
						data[off + 2] = 240;
						data[off + 3] = 34;
					} else {
						const poff = i * 4;
						data[off]     = palette[poff];
						data[off + 1] = palette[poff + 1];
						data[off + 2] = palette[poff + 2];
						data[off + 3] = palette[poff + 3];
					}
				}
			}
			ctx.putImageData(img, 0, 0);
		}

		function setup() {
			const stage = document.getElementById("f-stage");
			if (!stage) return;
			const mandel = stage.querySelector<HTMLCanvasElement>("canvas.f-mandel");
			const orbitCv = stage.querySelector<HTMLCanvasElement>("canvas.f-orbit");
			const readC = document.getElementById("f-c-readout");
			const readStatus = document.getElementById("f-status");
			if (!mandel || !orbitCv) return;
			const token = ++genToken;

			const state = {
				w: 0, h: 0, scale: 1,
				cR: IDLE_RE, cI: IDLE_IM,
				locked: false,
				status: "",
			};

			function layout() {
				const rect = stage!.getBoundingClientRect();
				state.w = Math.max(1, Math.round(rect.width));
				state.h = Math.max(1, Math.round(rect.height));
				// Whole set (re ∈ [-2.4, 2.4], im ∈ [-1.4, 1.4]) and the ƒ-point
				// stay on-stage at every aspect ratio.
				state.scale = Math.min(state.w / 4.8, state.h / 2.8);
				orbitCv!.width = state.w;
				orbitCv!.height = state.h;
				// Static set renders at reduced backing resolution; CSS upscales
				// with image-rendering: pixelated.
				const f = Math.min(1, 960 / state.w);
				mandel!.width = Math.max(1, Math.round(state.w * f));
				mandel!.height = Math.max(1, Math.round(state.h * f));
				renderMandel(mandel!, state.scale * f);
			}

			let resizeTimer = 0;
			const onResize = () => {
				window.clearTimeout(resizeTimer);
				resizeTimer = window.setTimeout(layout, 150);
			};
			window.addEventListener("resize", onResize);

			function drawOrbit(now: number) {
				const ctx = orbitCv!.getContext("2d");
				if (!ctx) return;
				const W = state.w, H = state.h, s = state.scale;
				const cx = W / 2, cy = H / 2;
				const ink = state.locked ? AMBER : MINT;
				ctx.clearRect(0, 0, W, H);

				// Axes through the origin + dashed escape circle |z| = 2.
				ctx.strokeStyle = `rgba(${MINT},0.16)`;
				ctx.lineWidth = 1;
				ctx.beginPath();
				ctx.moveTo(0, cy); ctx.lineTo(W, cy);
				ctx.moveTo(cx, 0); ctx.lineTo(cx, H);
				ctx.stroke();
				ctx.setLineDash([2, 5]);
				ctx.strokeStyle = `rgba(${MINT},0.12)`;
				ctx.beginPath();
				ctx.arc(cx, cy, 2 * s, 0, Math.PI * 2);
				ctx.stroke();
				ctx.setLineDash([]);

				// ƒ-point marker — dashed ring showing the exact lock zone.
				const fx = cx + F_RE * s;
				const fy = cy - F_IM * s;
				const ringR = LOCK_RADIUS * s;
				const pulse = reduced || state.locked ? 1 : 0.65 + 0.35 * Math.sin(now / 480);
				ctx.setLineDash(state.locked ? [] : [3, 4]);
				ctx.strokeStyle = `rgba(${ink},${0.75 * pulse})`;
				ctx.lineWidth = state.locked ? 1.5 : 1;
				ctx.beginPath();
				ctx.arc(fx, fy, ringR, 0, Math.PI * 2);
				ctx.stroke();
				ctx.setLineDash([]);
				ctx.fillStyle = `rgba(${ink},${0.9 * pulse})`;
				ctx.font = `italic 600 ${Math.max(16, Math.round(s * 0.1))}px "STIX Two Text", "Cambria Math", Cambria, Georgia, serif`;
				ctx.textBaseline = "bottom";
				ctx.fillText("ƒ", fx + ringR + 5, fy - ringR - 2);
				if (state.locked) {
					ctx.font = '10px "JetBrains Mono", monospace';
					ctx.textBaseline = "top";
					ctx.fillStyle = `rgba(${ink},0.85)`;
					ctx.fillText("0.300 + 0.850i", fx + ringR + 5, fy + ringR + 4);
				}

				// Orbit of 0 under z → z² + c — connected points, capped once
				// |z| clears the escape radius by a wide margin.
				const pts: [number, number][] = [[0, 0]];
				let zR = 0, zI = 0;
				let escaped = -1;
				for (let i = 0; i < ORBIT_ITER; i++) {
					const r2 = zR * zR;
					const i2 = zI * zI;
					if (r2 + i2 > 16) { escaped = i; break; }
					zI = 2 * zR * zI + state.cI;
					zR = r2 - i2 + state.cR;
					pts.push([zR, zI]);
				}
				ctx.strokeStyle = `rgba(${ink},0.5)`;
				ctx.lineWidth = 1;
				ctx.beginPath();
				pts.forEach(([re, im], i) => {
					const x = cx + re * s;
					const y = cy - im * s;
					if (i === 0) ctx.moveTo(x, y);
					else ctx.lineTo(x, y);
				});
				ctx.stroke();
				ctx.fillStyle = `rgba(${ink},0.9)`;
				pts.forEach(([re, im], i) => {
					const d = i === 0 ? 4 : 2.5;
					ctx.fillRect(cx + re * s - d / 2, cy - im * s - d / 2, d, d);
				});
				return escaped;
			}

			function tick(now: number) {
				if (token !== genToken || !document.body.contains(stage)) return;
				const rect = stage!.getBoundingClientRect();
				const originX = rect.left + rect.width / 2;
				const originY = rect.top + rect.height / 2;
				const targetR = pointer.active ? (pointer.x - originX) / state.scale : IDLE_RE;
				const targetI = pointer.active ? (originY - pointer.y) / state.scale : IDLE_IM;
				const k = reduced ? 1 : 0.12;
				state.cR += (targetR - state.cR) * k;
				state.cI += (targetI - state.cI) * k;

				// Lock on the raw cursor c — the tip must actually reach ƒ.
				const locked = Math.hypot(targetR - F_RE, targetI - F_IM) < LOCK_RADIUS;
				if (locked !== state.locked) {
					state.locked = locked;
					stage!.classList.toggle("f-locked", locked);
				}

				const escaped = drawOrbit(now);

				if (readC) {
					const sign = state.cI >= 0 ? "+" : "−";
					readC.textContent = `C = ${state.cR.toFixed(3)} ${sign} ${Math.abs(state.cI).toFixed(3)}i`;
				}
				const status = locked
					? "ƒ · LOCKED"
					: escaped === undefined || escaped < 0
						? `● BOUNDED · ${ORBIT_ITER} ITER`
						: `● ESCAPES @ N=${escaped}`;
				if (readStatus && status !== state.status) {
					state.status = status;
					readStatus.textContent = status;
				}

				requestAnimationFrame(tick);
			}

			layout();
			requestAnimationFrame(tick);
		}

		document.addEventListener("astro:page-load", setup);
		setup();
	}
</script>
