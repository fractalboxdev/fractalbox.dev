---
import Layout from "../../../layouts/FractalMay2026.astro";
import BoxDimChip from "../../../components/BoxDimChip.astro";
import { pillars, contact, boxLine } from "../../../data/spec";
import { sierpinskiPolygons, kochSnowflakePath } from "../../../data/fractals";

const pillarExtended = [
	{
		artifact: "specs/approach/threat-model-template.md",
		standards: "STRIDE · LINDDUN · MITRE ATT&CK",
		concrete: "We default to CRDTs (Yjs / Automerge), on-device encryption (libsodium), and offline-capable UX. Sync runs over WebSockets when available, queued mailbox when not.",
	},
	{
		artifact: "specs/approach/data-residency.md",
		standards: "GDPR · MAS TRM 11.1.5 · HIPAA",
		concrete: "Minimum data collected, minimum data retained. Threat models include the operator. We deploy data classification labels at the column level, not the policy level.",
	},
	{
		artifact: "specs/approach/soc2-readiness.md",
		standards: "SOC2 Type II · ISO27001 · MAS TRM",
		concrete: "Designed in from day one. Drata or Vanta-aligned controls, mapped policies, evidence collection automated against AWS / GCP / Cloudflare APIs.",
	},
	{
		artifact: "specs/approach/sbom-workflow.md",
		standards: "STRIDE · SLSA L3 · CycloneDX SBOM",
		concrete: "Pinned dependencies, signed releases (Sigstore), audited transitives. Pull-request gates with semgrep + osv-scanner. Supply-chain compromises caught at PR time.",
	},
];
---
<Layout
	title="fractal.box — approach · may 2026"
	active="approach"
	iter={3}
	pageTag="§III · APPROACH"
	pageGreek="ƒ³(△) — dim_H = log 3 / log 2 ≈ 1.585"
>
	<section style="padding-top:4rem;">
		<div class="wrap">
			<div class="eyebrow"><span class="blink"></span> // §III · the discipline</div>
			<h1 class="serif-h1">The shape of attention, drawn at four resolutions.</h1>
			<p class="serif-lede">
				Our differentiator is not the deliverable; it is the discipline applied to every deliverable.
				Below, the same Sierpinski triangle iterates four times. That&rsquo;s a picture of what
				&ldquo;same rigour at every scale&rdquo; means.
			</p>

			<div style="margin-top:3rem; display:grid; grid-template-columns:repeat(4, 1fr); gap:0; border:1px solid var(--border-hi); background:var(--bg-card);">
				{[1, 2, 3, 4].map((d, i) => (
					<div
						class="iter-cell"
						style={`
							padding:1.5rem; border-right:${i < 3 ? "1px solid var(--border)" : "none"};
							display:flex; flex-direction:column; align-items:center; gap:0.6rem;
							animation: iter-cascade 6s cubic-bezier(0.16, 1, 0.3, 1) infinite;
							animation-delay: ${i * 0.4}s;
						`}
					>
						<svg viewBox="-50 -50 100 100" aria-hidden="true" style="width:100%; max-width:120px; aspect-ratio:1; color:var(--mint);">
							<g stroke="currentColor" fill="none" stroke-width="1">
								{sierpinskiPolygons(d, 88, 0, 0).map((pts) => <polygon points={pts}/>)}
							</g>
						</svg>
						<div style="font-family:'JetBrains Mono',monospace; font-size:0.72rem; letter-spacing:0.16em; text-transform:uppercase; color:var(--muted);">d = <span style="color:var(--mint);">{d}</span></div>
						<div class="serif-h3" style="font-size:0.95rem; text-align:center; margin:0; font-style:italic; color:var(--muted);">
							{["pillar i", "pillar ii", "pillar iii", "pillar iv"][i]}
						</div>
					</div>
				))}
			</div>
			<div style="margin-top:1.25rem; display:flex; gap:1rem; flex-wrap:wrap; align-items:center; --chip-color: var(--mint); --chip-border: var(--border-hi); --chip-bg: var(--bg-elevated); --chip-name: var(--amber); --chip-val: var(--math);">
				<BoxDimChip for="sierpinski" />
				<span style="font-family:'JetBrains Mono',monospace; font-size:0.78rem; letter-spacing:0.06em; color:var(--muted);">
					// invariant across d ∈ {1, 2, 3, 4} — that&rsquo;s the claim
				</span>
			</div>
		</div>
	</section>

	<div class="wrap koch-divider" aria-hidden="true">
		<svg viewBox="-600 -14 1200 28" preserveAspectRatio="none">
			<path d="M-600,0 L600,0" fill="none" stroke="currentColor" stroke-width="0.6" stroke-dasharray="2 6"/>
		</svg>
	</div>

	<section>
		<div class="wrap">
			<div class="section-tag"><span class="dot"></span> // four pillars · long form</div>
			<h2 class="serif-h2">Each pillar, with the artifact behind it.</h2>
			<p class="lede">Open-source by default. The approach lives in markdown under <code style="color:var(--amber); font-family:'JetBrains Mono',monospace;">specs/approach/</code>.</p>

			<div style="display:grid; gap:0; margin-top:2.5rem; border-top:1px solid var(--border);">
				{pillars.map((p, i) => (
					<article style="display:grid; grid-template-columns:1fr; gap:1.5rem; padding:2.5rem 0; border-bottom:1px solid var(--border);">
						<div style="display:grid; gap:1.5rem; grid-template-columns:120px 1fr;">
							<svg viewBox="-50 -50 100 100" aria-hidden="true" style="width:120px; height:120px; color:var(--mint); flex:0 0 auto;">
								<g stroke="currentColor" fill="none" stroke-width="0.9">
									{sierpinskiPolygons(i + 1, 88, 0, 0).map((pts) => <polygon points={pts}/>)}
								</g>
							</svg>
							<div>
								<div style="color:var(--mint); font-family:'JetBrains Mono',monospace; font-size:0.72rem; letter-spacing:0.2em; text-transform:uppercase;">PILLAR · {p.n} · DEPTH {i + 1}</div>
								<h3 class="serif-h3" style="font-size:1.6rem; margin:0.4rem 0;">{p.name}</h3>
								<p class="serif-lede" style="font-size:1.05rem; margin:0;">{p.body}</p>
							</div>
						</div>

						<div style="display:grid; grid-template-columns:1fr; gap:1rem;">
							<div style="padding:1rem 1.25rem; border:1px solid var(--border); background:var(--bg-card);">
								<div style="color:var(--amber); font-family:'JetBrains Mono',monospace; font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; margin-bottom:0.5rem;">// what we actually do</div>
								<p style="margin:0; color:var(--fg); font-size:0.95rem;">{pillarExtended[i].concrete}</p>
							</div>
							<div style="display:grid; gap:0.5rem; grid-template-columns:1fr 1fr; font-family:'JetBrains Mono',monospace; font-size:0.8rem;">
								<div style="padding:0.7rem 1rem; border:1px solid var(--border); background:var(--bg-elevated);">
									<div style="color:var(--muted); font-size:0.65rem; letter-spacing:0.18em; text-transform:uppercase;">artifact</div>
									<div style="color:var(--mint); margin-top:0.2rem; word-break:break-all;">{pillarExtended[i].artifact}</div>
								</div>
								<div style="padding:0.7rem 1rem; border:1px solid var(--border); background:var(--bg-elevated);">
									<div style="color:var(--muted); font-size:0.65rem; letter-spacing:0.18em; text-transform:uppercase;">standards</div>
									<div style="color:var(--amber); margin-top:0.2rem;">{pillarExtended[i].standards}</div>
								</div>
							</div>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<section>
		<div class="wrap" style="text-align:center;">
			<div class="section-tag" style="justify-content:center;"><span class="dot"></span> // signal &amp; noise</div>
			<svg viewBox="-100 -100 200 200" aria-hidden="true" style="width:200px; height:200px; margin:1rem auto; color:var(--amber); display:block; animation: koch-rotate 80s linear infinite;">
				<path d={kochSnowflakePath(4, 180, 0, 0)} fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.7"/>
				<path d={kochSnowflakePath(3, 180, 0, 0)} fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.4"/>
			</svg>
			<p class="serif-lede" style="margin:1rem auto 1.5rem; max-width:32rem;">
				Rigour scales with engagement. The <em>shape</em> doesn&rsquo;t change.
			</p>
			<a class="btn primary" href={`mailto:${contact.email}`}>↪ start a discussion</a>
		</div>
	</section>

	<style>
		@keyframes iter-cascade {
			0%, 60%, 100% { opacity: 0.55; filter: drop-shadow(0 0 0 transparent); }
			15%           { opacity: 1; filter: drop-shadow(0 0 12px rgba(176,222,240,0.7)); }
		}
		@keyframes koch-rotate { to { transform: rotate(360deg); } }
		@media (prefers-reduced-motion: reduce) {
			.iter-cell, svg[style*="koch-rotate"] { animation: none !important; }
		}
	</style>
</Layout>
